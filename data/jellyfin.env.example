# Copy to data/jellyfin.env before running docker compose (data/ is gitignored).
# These values are read by the Torfin Docker server at runtime.

PORT=3020
TORBOX_DATA_DIR=/data
TORBOX_DOWNLOAD_DIR=/media/movies
JELLYFIN_URL=http://jellyfin.local:8096
JELLYFIN_API_KEY=your_jellyfin_api_key
JELLYFIN_PATH_MAP_FROM=/media/movies
JELLYFIN_PATH_MAP_TO=/movies
TORBOX_SERVER_API_KEY=choose_a_long_random_server_key
TORBOX_ARIA2_SPLIT=16
TORBOX_ARIA2_CONNECTIONS=16
TORBOX_ARIA2_CONCURRENT_DOWNLOADS=10
TORBOX_ARIA2_MIN_SPLIT_SIZE=1M
