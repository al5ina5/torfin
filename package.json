{
  "name": "torfin",
  "private": false,
  "version": "1.0.0-beta.2",
  "type": "module",
  "scripts": {
    "dev": "concurrently -k -n web,api -c green,blue \"vite\" \"PORT=3020 NODE_ENV=development node server.mjs\"",
    "tauri:dev": "tauri dev",
    "generate:pwa-splash": "node scripts/generate-pwa-splash.mjs",
    "build": "npm run generate:pwa-splash && tsc -b && vite build",
    "tauri:build": "tauri build",
    "lint": "oxlint",
    "preview": "vite preview",
    "test": "vitest run",
    "test:web-downloads": "node scripts/test-web-downloads.mjs",
    "test:ui": "node scripts/ui-smoke-test.mjs",
    "test:kiosk": "node scripts/test-kiosk-navigation.mjs",
    "test:catalog-nav": "node scripts/test-catalog-navigation.mjs",
    "test:focus": "npm run test -- --run src/lib/focus-navigation && npm run test:catalog-nav && npm run test:kiosk",
    "test:bug-hunt": "node scripts/bug-hunt.mjs",
    "test:ui:all": "node scripts/ui-smoke-test.mjs && node scripts/bug-hunt.mjs",
    "test:transcode": "node scripts/test-transcode-pipeline.mjs",
    "test:server-api": "node scripts/test-server-api.mjs",
    "test:stability": "npm run lint && npm run test && npm run build && npm run test:transcode && npm run test:web-downloads && npm run test:server-api",
    "test:all": "node scripts/test-all.mjs",
    "errors": "node scripts/errors-summary.mjs",
    "thinktower": "node scripts/deploy-thinktower.mjs",
    "install:hooks": "bash scripts/install-git-hooks.sh"
  },
  "dependencies": {
    "@tauri-apps/api": "^2.11.1",
    "lucide-react": "^1.21.0",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "sonner": "^2.0.7",
    "swr": "^2.4.2",
    "video.js": "^8.23.8"
  },
  "devDependencies": {
    "@tailwindcss/vite": "^4.3.1",
    "@tauri-apps/cli": "^2.11.3",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/react": "^16.3.2",
    "@types/node": "^24.13.2",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.2",
    "concurrently": "^9.2.3",
    "happy-dom": "^20.10.6",
    "oxlint": "^1.69.0",
    "playwright": "^1.61.1",
    "tailwindcss": "^4.3.1",
    "typescript": "~6.0.2",
    "vite": "^8.1.0",
    "vite-plugin-pwa": "^1.3.0",
    "vitest": "^3.2.6"
  }
}
