# Copy to .env.deploy or .env.thinktower (both are gitignored).
# Used by: npm run thinktower

DEPLOY_HOST=your-server.local
DEPLOY_USER=your-ssh-username
DEPLOY_PASSWORD=your-ssh-password
# DEPLOY_SSH_KEY=/path/to/private_key

DEPLOY_REMOTE_DIR=~/torfin
DEPLOY_LEGACY_DATA_DIR=/path/to/torfin/data
DEPLOY_ENV_FILE=/path/to/torfin/data/jellyfin.env
DEPLOY_MEDIA_PATH=/path/to/jellyfin/movies
# DEPLOY_LEGACY_PROJECT=old-container-name
DEPLOY_PORT=3020
# DEPLOY_URL=http://your-server.local:3020/api/health
